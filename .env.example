# ==================== 应用配置 ====================
APP_NAME=Metis_ParseBot
DEBUG=false
LOG_LEVEL=INFO

# ==================== LLM API 配置 ====================
# OpenAI API (必填，或填写 ANTHROPIC_API_KEY)
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_API_BASE=https://api.openai.com/v1
MODEL_NAME=gpt-4
MODEL_TEMPERATURE=0.7
MAX_TOKENS=4000

# Anthropic API (可选，作为备用)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# ==================== 数据库配置 ====================
DATABASE_URL=sqlite+aiosqlite:///./data/metis.db
DATABASE_ECHO=false

# ==================== 采集配置 ====================
COLLECT_INTERVAL_HOURS=6
MAX_ITEMS_PER_RUN=50
COLLECT_TIMEOUT_SECONDS=30

# arXiv 配置
ARXIV_CATEGORIES=["cs.AI", "cs.CL", "cs.LG", "cs.CR", "cs.CV"]
ARXIV_MAX_RESULTS=20

# 新闻源配置
NEWS_SOURCES=["hackernews", "reddit_ml", "reddit_security"]

# ==================== 预审配置 ====================
PASSING_SCORE=60

# ==================== 分析配置 ====================
MAX_KNOWLEDGE_LINKS=5
MAX_KEY_POINTS=10

# ==================== API 服务配置 ====================
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1
CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173"]

# ==================== 缓存配置 ====================
ENABLE_CACHE=true
CACHE_TTL_SECONDS=3600
